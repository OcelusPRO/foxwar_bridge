{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Foxwar Bridge",
  "version": "0.1.0",
  "identifier": "net.foxwar.bridge",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Foxwar Bridge",
        "width": 520,
        "height": 620,
        "resizable": false,
        "center": true,
        "visible": true,
        "decorations": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["foxwar"]
      }
    }
  }
}
